# DeepSeek API Key,从 https://platform.deepseek.com/api_keys 申请
# 本地运行时复制本文件为 .env 并填入真实 key
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 安全密钥(必填,缺失将拒绝启动)───
# 生成随机串:python3 -c "import secrets;print(secrets.token_hex(32))"
# SESSION_SECRET:会话 Token 的 HMAC 签名密钥。更换会使全员需重新登录。
SESSION_SECRET=请填64位随机十六进制串
# ID6_SALT:身份证后6位哈希盐。⚠️ 一旦有用户数据后不可随意更换,否则已存哈希全部失效。
ID6_SALT=请填64位随机十六进制串
# KOS_IMG_SECRET:KOS 成品图下载令牌签名密钥(可选,未配置时部分实现回退其他密钥)。
KOS_IMG_SECRET=请填64位随机十六进制串

# ─── 限流(可选,按 AI 额度调参)───
# RL_PER_MIN=10
# RL_PER_DAY=200

# ─── 豆包(火山引擎)图像 API ───
DOUBAO_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── 腾讯云对象存储 COS(产品资料库下载用)───
# 子账号密钥:https://console.cloud.tencent.com/cam/capi (建议用只读子账号,别用主账号密钥)
COS_SECRET_ID=AKIDxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COS_SECRET_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COS_REGION=ap-shanghai
# 桶名要带 APPID,形如 johnson-1250000000
COS_BUCKET=your-bucket-1250000000
# 上传时的对象 Key 前缀:若你把整个「产品库」文件夹传上去,就是「产品库/」
COS_PREFIX=产品库/
# 下载链接有效期(秒),默认 300(5 分钟)
COS_URL_EXPIRE=300
